# 复制为 .env 并按需修改。所有配置都通过环境变量注入(12-Factor / 云原生实践)。

# --- 服务发现:本地默认 localhost;容器/K8s 用服务名;对接现有系统填其地址 ---
ORDER_URL=http://localhost:8001
PRODUCT_URL=http://localhost:8002
LOGISTICS_URL=http://localhost:8003

# ===========【大模型 API Key 就在这里填】===========
# 复制本文件为 .env( cp .env.example .env ),把 key 填到下面这行 = 后面。
# 留空 = 用离线教学桩(无需联网);填上 = 调用真实大模型。llm.py 启动时自动读取 .env。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen-plus
# ===================================================

# --- 导购增强配置 ---
SHOPPING_AGENT_MODE=auto
PRODUCT_SOURCE=demo
# auto: 有真实LLM则用真实LLM推理，没有则回退规则推荐
# demo: 使用本地演示商品数据作为证据源
# live: 预留真实数据采集模式，当前失败时自动回退 demo

# --- 检索条数(实验4演示评测驱动改进)---
POLICY_K=2
